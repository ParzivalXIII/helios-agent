# LLM Configuration
# Base URL for the LLM provider API (e.g., OpenRouter, OpenAI, Anthropic)
# Example: https://api.openrouter.ai/api/v1
LLM_BASE_URL=https://api.openrouter.ai/api/v1

# The LLM model identifier to use for chat completions
# Example: openrouter/anthropic/claude-3.5-sonnet
# (Change to your preferred model)
LLM_MODEL=openrouter/anthropic/claude-3.5-sonnet

# Redis Configuration
# Connection URL for the Redis instance used for session state storage
# Format: redis://[username]:[password]@host:port/database
# Default for local development: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Agent Behavior Configuration
# Maximum number of turns (request-response cycles) per session before timeout
# Prevents infinite loops and uncontrolled escalation
MAX_TURNS=5

# Session state time-to-live in seconds
# After this time, a session is automatically deleted from Redis
# 3600 seconds = 1 hour
SESSION_TTL_SECONDS=3600

# Tool execution timeout in milliseconds
# Maximum time allowed for a single tool invocation before timeout
# Includes retry attempts and fallback execution
TOOL_TIMEOUT_MS=5000

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG: Verbose output for troubleshooting
# INFO: General operational messages (recommended for production)
# WARNING: Warning and error messages only
LOG_LEVEL=INFO

# MCP Configuration Path
# Relative or absolute path to the mcp_servers.yaml configuration file
# This file defines all available MCP servers and their connection details
MCP_CONFIG_PATH=./config/mcp_servers.yaml
